# Database config
DATABASE_URL=postgresql://user:password@host:port/dbname

# AI - Ollama config
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b

# Instagram Graph API config
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token
INSTAGRAM_BUSINESS_ID=your_instagram_business_id

# Public Host (for media URLs in local dev, e.g. ngrok)
PUBLIC_HOST=http://localhost:8000

# Security settings
ADMIN_USER=admin
ADMIN_PASSWORD=change_me_to_something_secure
JWT_SECRET=change_me_to_something_secure_jwt
CRON_SECRET=change_me_to_something_secure_cron
